{
  "name": "o3-shop/google-recaptcha-module",
  "description": "Google reCAPTCHA v2/v3 provider for the O3-Shop core CAPTCHA layer",
  "type": "oxideshop-module",
  "homepage": "https://www.o3-shop.com/",
  "license": "GPL-3.0",
  "authors": [
    {
      "name": "O3-Shop",
      "email": "info@o3-shop.com"
    }
  ],
  "require": {
    "php": ">=8.0",
    "google/recaptcha": "^1.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^9"
  },
  "autoload": {
    "psr-4": {
      "O3Shop\\ReCaptcha\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "O3Shop\\ReCaptcha\\Tests\\": "tests/"
    }
  },
  "extra": {
    "oxideshop": {
      "target-directory": "o3-shop/recaptcha"
    }
  }
}
